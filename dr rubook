Test-NetConnection <DC-IP> -Port 88
Test-NetConnection <DC-IP> -Port 135
Test-NetConnection <DC-IP> -Port 389
Test-NetConnection <DC-IP> -Port 445
Test-NetConnection <DC-IP> -Port 636
Example:
Test-NetConnection 10.134.127.232 -Port 53
Test-NetConnection 10.134.127.232 -Port 389
Test-NetConnection 10.134.127.232 -Port 445
